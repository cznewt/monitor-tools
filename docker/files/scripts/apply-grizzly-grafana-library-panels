#!/bin/bash

BUILD_DIR="${BUILD_DIR:=/build/default/grizzly/grafana-library-panels}"

yaml_files=$(find "$BUILD_DIR" -maxdepth 1 -type f -name "*.yaml" 2>/dev/null)

# Library panels are optional; an empty/absent build dir is not an error.
if [ -z "$yaml_files" ]; then echo "No grizzly GrafanaLibraryPanels in '$BUILD_DIR', skipping."; exit 0; fi

if [ -z "$GRAFANA_URL" ]; then echo "GRAFANA_URL not set, cannot connect to Grafana server."; exit 1; fi
if [ -z "$GRAFANA_TOKEN" ]; then echo "GRAFANA_TOKEN not set, cannot connect to Grafana server."; exit 1; fi

for yaml_file in $yaml_files; do
  echo "Applying $yaml_file grizzly GrafanaLibraryPanels to $GRAFANA_URL..."
  grr apply $yaml_file --disable-reporting
done
